{
  "manifest_version": 3,
  "name": "Open to Borderless",
  "description": "Open links in borderless windows with middle-click + modifier",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "window.html",
    "default_title": "Open to Borderless"
  }
}
